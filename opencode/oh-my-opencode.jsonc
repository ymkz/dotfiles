{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true
  },
  "agents": {
    "sisyphus": { "model": "opencode-go/kimi-k2.5" },
    "prometheus": { "model": "opencode-go/kimi-k2.5" },
    "atlas": { "model": "opencode-go/kimi-k2.5" },
    "oracle": { "model": "opencode-go/glm-5" },
    "librarian": { "model": "opencode-go/minimax-m2.5" },
    "explore": { "model": "opencode-go/minimax-m2.5" },
    "hephaestus": { "model": "opencode-go/minimax-m2.5" },
    "sisyphus-junior": { "model": "opencode-go/minimax-m2.5" }
  },
  "categories": {
    "quick": { "model": "opencode-go/minimax-m2.5" },
    "unspecified-low": { "model": "opencode-go/minimax-m2.5" },
    "unspecified-high": { "model": "opencode-go/glm-5" },
    "writing": { "model": "opencode-go/kimi-k2.5" },
    "visual-engineering": { "model": "opencode-go/glm-5" }
  }
}
